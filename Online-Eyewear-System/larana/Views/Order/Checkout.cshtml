@model OpticalStore.WebApplication.Models.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
}

<div style="max-width:960px;margin:3rem auto;padding:0 1rem;">

    <h1 style="font-family:var(--font-display);font-size:var(--text-3xl);color:var(--charcoal);margin-bottom:0.5rem;">Thanh toán</h1>
    <p style="color:var(--gray-500);margin-bottom:2rem;">Kiểm tra đơn hàng và điền thông tin giao hàng.</p>

    @if (TempData["Error"] != null)
    {
        <div style="background:#fee2e2;color:#991b1b;padding:12px 16px;border-radius:8px;margin-bottom:1.5rem;font-size:14px;">
            ✕ @TempData["Error"]
        </div>
    }

    <div style="display:grid;grid-template-columns:1fr 340px;gap:2rem;align-items:start;">

        @* Left: form *@
        <div>
            <form asp-action="Checkout" method="post">

                @* Thông tin giao hàng *@
                <div style="background:var(--white);border:1px solid var(--gray-100);border-radius:var(--radius-lg);padding:1.5rem;margin-bottom:1.5rem;box-shadow:var(--shadow-sm);">
                    <h3 style="font-family:var(--font-display);font-size:1.15rem;color:var(--charcoal);margin-bottom:1.25rem;display:flex;align-items:center;gap:8px;">
                        📍 Thông tin giao hàng
                    </h3>
                    <div class="form-group">
                        <label for="shippingAddress">Địa chỉ nhận hàng <span style="color:#dc2626">*</span></label>
                        <textarea id="shippingAddress" name="shippingAddress" rows="3"
                            placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành..." required>@Model.ShippingAddress</textarea>
                    </div>
                    <div class="form-group" style="margin-bottom:0;">
                        <label for="note">Ghi chú (tùy chọn)</label>
                        <textarea id="note" name="note" rows="2"
                            placeholder="Ví dụ: Gọi trước khi giao, giao giờ hành chính..."></textarea>
                    </div>
                </div>

                @* Loại đơn hàng *@
                <div style="background:var(--white);border:1px solid var(--gray-100);border-radius:var(--radius-lg);padding:1.5rem;margin-bottom:1.5rem;box-shadow:var(--shadow-sm);">
                    <h3 style="font-family:var(--font-display);font-size:1.15rem;color:var(--charcoal);margin-bottom:1.25rem;">
                        📦 Loại đơn hàng
                    </h3>

                    @foreach (var opt in new[] {
                        ("standard",    "🛍 Mua kính có sẵn",       "Nhận hàng trong 1–3 ngày làm việc."),
                        ("pre_order",   "⏳ Đặt trước (Pre-order)",  "Sản phẩm sẽ có trong 7–14 ngày."),
                        ("prescription","🔬 Làm kính theo đơn",      "Cần đơn từ bác sĩ nhãn khoa. Thời gian 5–10 ngày.")
                    })
                    {
                        <label style="display:flex;align-items:flex-start;gap:12px;padding:14px;border:1.5px solid var(--gray-100);border-radius:var(--radius-md);margin-bottom:10px;cursor:pointer;transition:border-color 0.15s;" 
                               onmouseover="this.style.borderColor='var(--primary-orange-light)'"
                               onmouseout="this.style.borderColor='var(--gray-100)'">
                            <input type="radio" name="orderType" value="@opt.Item1"
                                   @(opt.Item1 == "standard" ? "checked" : "")
                                   style="margin-top:3px;accent-color:var(--primary-orange);" />
                            <div>
                                <div style="font-weight:600;color:var(--charcoal);font-size:14px;">@opt.Item2</div>
                                <div style="font-size:13px;color:var(--gray-500);margin-top:2px;">@opt.Item3</div>
                            </div>
                        </label>
                    }
                </div>

                <button type="submit" class="btn btn--primary" style="width:100%;padding:16px;font-size:16px;font-weight:600;">
                    Đặt hàng ngay →
                </button>
            </form>
        </div>

        @* Right: order summary *@
        <div style="background:var(--white);border:1px solid var(--gray-100);border-radius:var(--radius-lg);padding:1.5rem;box-shadow:var(--shadow-sm);position:sticky;top:90px;">
            <h3 style="font-family:var(--font-display);font-size:1.1rem;color:var(--charcoal);margin-bottom:1.25rem;">
                🧾 Đơn hàng của bạn
            </h3>

            @foreach (var item in Model.CartItems)
            {
                var price = item.Variant?.Price ?? 0;
                var product = OpticalStore.WebApplication.Models.StaticData.Products
                                .FirstOrDefault(p => p.Variants.Any(v => v.VariantId == item.VariantId));
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;padding-bottom:12px;border-bottom:1px solid var(--gray-100);">
                    <div style="width:44px;height:44px;border-radius:6px;background:var(--accent-cream);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1.2rem;">
                        👓
                    </div>
                    <div style="flex:1;min-width:0;">
                        <div style="font-size:13px;font-weight:600;color:var(--charcoal);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                            @(product?.Name ?? "Sản phẩm")
                        </div>
                        <div style="font-size:12px;color:var(--gray-500);">
                            @(item.Variant?.Color) / @(item.Variant?.Size) × @item.Quantity
                        </div>
                    </div>
                    <div style="font-size:13px;font-weight:600;color:var(--charcoal);flex-shrink:0;">
                        @((price * item.Quantity).ToString("N0"))₫
                    </div>
                </div>
            }

            <div style="display:flex;justify-content:space-between;font-size:13px;color:var(--gray-500);margin-bottom:6px;">
                <span>Tạm tính</span><span>@Model.Total.ToString("N0")₫</span>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:13px;color:#16a34a;margin-bottom:1rem;">
                <span>Vận chuyển</span><span>Miễn phí</span>
            </div>
            <div style="height:1px;background:var(--gray-100);margin-bottom:1rem;"></div>
            <div style="display:flex;justify-content:space-between;align-items:center;">
                <span style="font-weight:700;font-size:1rem;color:var(--charcoal);">Tổng cộng</span>
                <span style="font-weight:700;font-size:1.3rem;color:var(--primary-orange);">@Model.Total.ToString("N0")₫</span>
            </div>

            <a asp-controller="Cart" asp-action="Index" style="display:block;text-align:center;font-size:13px;color:var(--gray-500);margin-top:1rem;">
                ← Sửa giỏ hàng
            </a>
        </div>
    </div>
</div>

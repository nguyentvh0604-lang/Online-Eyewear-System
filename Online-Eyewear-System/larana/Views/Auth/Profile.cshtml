@model OpticalStore.WebApplication.Models.AppUser
@{
    ViewData["Title"] = "Tài khoản của tôi";
}

<div style="max-width:640px;margin:3rem auto;padding:0 1rem;">

    <h2 style="font-family:var(--font-display);font-size:var(--text-3xl);color:var(--charcoal);margin-bottom:2rem;">
        Tài khoản của tôi
    </h2>

    @if (Model == null)
    {
        <div style="background:#fee2e2;color:#991b1b;padding:16px;border-radius:8px;">
            Không tìm thấy thông tin tài khoản.
        </div>
    }
    else
    {
        <div style="background:var(--white);border:1px solid var(--gray-100);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-sm);">

            @* Avatar header *@
            <div style="background:linear-gradient(135deg,var(--primary-orange),var(--primary-gold));padding:2rem;display:flex;align-items:center;gap:1.5rem;">
                <div style="width:72px;height:72px;border-radius:50%;background:rgba(255,255,255,0.3);display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700;color:#fff;flex-shrink:0;">
                    @Model.FullName.Substring(0, 1).ToUpper()
                </div>
                <div>
                    <div style="font-size:1.25rem;font-weight:600;color:#fff;">@Model.FullName</div>
                    <div style="font-size:0.85rem;color:rgba(255,255,255,0.85);">@Model.Email</div>
                    <span style="display:inline-block;margin-top:6px;background:rgba(255,255,255,0.25);color:#fff;font-size:11px;font-weight:600;letter-spacing:0.06em;padding:2px 10px;border-radius:999px;text-transform:uppercase;">
                        @(Model.Role == "admin" ? "Quản trị viên" : "Khách hàng")
                    </span>
                </div>
            </div>

            @* Info rows *@
            <div style="padding:1.5rem;">
                @{
                    void InfoRow(string label, string value)
                    {
                        <div style="display:flex;align-items:center;padding:14px 0;border-bottom:1px solid var(--gray-100);">
                            <span style="width:140px;font-size:13px;color:var(--gray-500);font-weight:500;flex-shrink:0;">@label</span>
                            <span style="font-size:15px;color:var(--charcoal);">@(string.IsNullOrEmpty(value) ? "—" : value)</span>
                        </div>
                    }
                }
                @{ InfoRow("Họ và tên", Model.FullName); }
                @{ InfoRow("Email", Model.Email); }
                @{ InfoRow("Điện thoại", Model.Phone); }
                @{ InfoRow("Địa chỉ", Model.Address); }
            </div>

            @* Actions *@
            <div style="padding:1rem 1.5rem 1.5rem;display:flex;gap:12px;flex-wrap:wrap;">
                <a asp-controller="Order" asp-action="History" class="btn btn--primary btn--sm">
                    📦 Lịch sử đơn hàng
                </a>
                <a asp-controller="Cart" asp-action="Index" class="btn btn--ghost btn--sm">
                    🛍 Giỏ hàng
                </a>
                <a asp-controller="Auth" asp-action="Logout" class="btn btn--ghost btn--sm" style="margin-left:auto;color:var(--gray-500);">
                    Đăng xuất
                </a>
            </div>
        </div>
    }
</div>

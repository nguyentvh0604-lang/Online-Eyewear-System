@model ProductListViewModel
@{
    ViewData["Title"] = "Danh sách sản phẩm";
    ViewData["UseBootstrap"] = true;
}

<h4 class="mb-4"><i class="bi bi-grid me-2"></i>Sản phẩm</h4>

@* ── KHU VỰC 1: Form tìm kiếm + lọc danh mục (NV3 + NV2) ── *@
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" asp-controller="Product">
            <div class="row g-2 align-items-end">

                @* Ô tìm kiếm *@
                <div class="col-md-5">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-search me-1"></i>Tìm kiếm
                    </label>
                    <input type="text" name="keyword" value="@Model.Keyword"
                           class="form-control"
                           placeholder="Nhập tên sản phẩm, thương hiệu..." />
                </div>

                @* Dropdown lọc danh mục — FIX RZ1031: dùng asp-for thay inline C# *@
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-funnel me-1"></i>Danh mục
                    </label>
                    <select name="categoryId" class="form-select">
                        <option value="0">-- Tất cả danh mục --</option>
                        @foreach (var cat in Model.Categories)
                        {
                            if (Model.SelectedCategoryId == cat.CategoryId)
                            {
                                <option value="@cat.CategoryId" selected="selected">@cat.Name</option>
                            }
                            else
                            {
                                <option value="@cat.CategoryId">@cat.Name</option>
                            }
                        }
                    </select>
                </div>

                @* Nút hành động *@
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill">
                        <i class="bi bi-search"></i> Tìm
                    </button>
                    <a asp-action="Index" asp-controller="Product" class="btn btn-outline-secondary flex-fill">
                        <i class="bi bi-x-circle"></i> Xóa
                    </a>
                </div>

            </div>
        </form>
    </div>
</div>

@* ── KHU VỰC 2: Kiểm tra tồn kho theo SKU (NV2 + NV3) ── *@
<div class="card shadow-sm mb-4 border-warning">
    <div class="card-header bg-warning bg-opacity-10 fw-semibold">
        <i class="bi bi-box-seam me-1"></i>Kiểm tra tồn kho theo mã SKU
    </div>
    <div class="card-body">
        <form method="post" asp-action="CheckStock" asp-controller="Product">
            <input type="hidden" name="keyword"    value="@Model.Keyword" />
            <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
            <div class="row g-2 align-items-end">
                <div class="col-md-6">
                    <label class="form-label">Mã SKU (ví dụ: <code>RB5154-BLK-M</code>)</label>
                    <input type="text" name="sku" value="@Model.CheckedSku"
                           class="form-control" placeholder="Nhập mã SKU..." />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-warning w-100">
                        <i class="bi bi-search"></i> Kiểm tra
                    </button>
                </div>
            </div>
        </form>

        @* Hiển thị kết quả kiểm tra tồn kho *@
        @if (Model.StockResult != null)
        {
            <hr class="my-3" />
            if (!Model.StockResult.Found)
            {
                <div class="alert alert-danger mb-0">
                    <i class="bi bi-x-circle me-2"></i>
                    Không tìm thấy mã SKU: <strong>@Model.CheckedSku</strong>
                </div>
            }
            else
            {
                @* FIX RZ1010: Tính biến trước trong @{ } ở đầu block, không lồng vào foreach/if *@
                string alertClass, badgeClass, icon;
                if (Model.StockResult.Status == "Còn hàng")
                {
                    alertClass = "success"; badgeClass = "success"; icon = "bi-check-circle-fill";
                }
                else if (Model.StockResult.Status == "Còn ít")
                {
                    alertClass = "warning"; badgeClass = "warning text-dark"; icon = "bi-exclamation-triangle-fill";
                }
                else
                {
                    alertClass = "danger"; badgeClass = "danger"; icon = "bi-x-circle-fill";
                }
                <div class="alert alert-@alertClass mb-0">
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <span class="fs-5"><i class="bi @icon"></i></span>
                        <div>
                            <strong>SKU: @Model.StockResult.Sku</strong>
                            &nbsp;|&nbsp; Màu: @Model.StockResult.Color
                            &nbsp;|&nbsp; Size: @Model.StockResult.Size
                            &nbsp;|&nbsp; Giá: @Model.StockResult.Price.ToString("N0")₫
                        </div>
                        <span class="ms-auto badge bg-@badgeClass fs-6">
                            @Model.StockResult.Status (@Model.StockResult.Stock còn lại)
                        </span>
                    </div>
                </div>
            }
        }
    </div>
</div>

@* ── KHU VỰC 3: Danh sách sản phẩm (NV4 + NV5) ── *@
<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="text-muted">
        Tìm thấy <strong>@Model.TotalFound</strong> sản phẩm
        @if (!string.IsNullOrEmpty(Model.Keyword))
        {
            <text> cho "<em>@Model.Keyword</em>"</text>
        }
    </span>
</div>

@if (!Model.Products.Any())
{
    <div class="alert alert-info text-center py-5">
        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
        Không tìm thấy sản phẩm nào phù hợp.
        <br />
        <a asp-action="Index" asp-controller="Product" class="btn btn-outline-primary mt-3">
            Xem tất cả sản phẩm
        </a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var p in Model.Products)
        {
            @* FIX RZ1010: Tính badge bằng if/else thay vì @{ switch } lồng trong foreach *@
            string badgeColor, badgeIcon;
            if (p.StockStatus == "Còn hàng")
            {
                badgeColor = "success"; badgeIcon = "bi-check-circle";
            }
            else if (p.StockStatus == "Còn ít")
            {
                badgeColor = "warning"; badgeIcon = "bi-exclamation-triangle";
            }
            else
            {
                badgeColor = "danger"; badgeIcon = "bi-x-circle";
            }

            <div class="col">
                <div class="card h-100 shadow-sm product-card">
                    <img src="@p.ImageUrl" class="card-img-top"
                         alt="@p.Name" style="height:180px; object-fit:cover;" />
                    <div class="card-body d-flex flex-column">
                        <h6 class="card-title mb-1">@p.Name</h6>
                        <span class="badge bg-secondary mb-2" style="width:fit-content">
                            @p.Category?.Name
                        </span>
                        <p class="card-text text-muted small flex-grow-1"
                           style="overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">
                            @p.Description
                        </p>
                        <p class="fw-bold text-primary mb-2">
                            Từ @p.MinPrice.ToString("N0")₫
                        </p>
                        <div class="d-flex justify-content-between align-items-center gap-1 flex-wrap">
                            <span class="badge bg-@badgeColor">
                                <i class="bi @badgeIcon me-1"></i>@p.StockStatus
                                (@p.TotalStock)
                            </span>
                            <div class="d-flex gap-1">
                                <a asp-controller="Product" asp-action="Detail"
                                   asp-route-id="@p.ProductId"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye me-1"></i>Chi tiết
                                </a>
                                @if (p.Variants.Any(v => v.Stock > 0))
                                {
                                    <form asp-controller="Cart" asp-action="Add" method="post" style="display:inline;">
                                        <input type="hidden" name="variantId" value="@p.Variants.First(v => v.Stock > 0).VariantId" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <button type="submit" class="btn btn-primary btn-sm" title="Thêm vào giỏ">
                                            <i class="bi bi-cart-plus"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@model List<OpticalStore.WebApplication.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    ViewData["UseBootstrap"] = true;
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">🧾 Quản lý đơn hàng</h1>
            <p class="text-muted mb-0">Tổng: @Model.Count đơn</p>
        </div>
        <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">← Dashboard</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            ✓ @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <div style="font-size:3rem;">📭</div>
            <p>Chưa có đơn hàng nào.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm" style="border-radius:12px;overflow:hidden;">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Khách hàng</th>
                            <th>Ngày đặt</th>
                            <th>Loại</th>
                            <th>Sản phẩm</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Cập nhật</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            var user = OpticalStore.WebApplication.Models.StaticData.GetUserById(order.UserId);
                            var badgeClass = order.Status switch
                            {
                                "completed" => "bg-success",
                                "cancelled" => "bg-danger",
                                "shipping"  => "bg-primary",
                                _           => "bg-warning text-dark"
                            };
                            var statusLabel = order.Status switch
                            {
                                "completed" => "Hoàn thành",
                                "cancelled" => "Đã hủy",
                                "shipping"  => "Đang giao",
                                _           => "Chờ xử lý"
                            };
                            <tr>
                                <td class="fw-bold">#@order.OrderId</td>
                                <td>
                                    <div class="fw-semibold">@(user?.FullName ?? "—")</div>
                                    <div class="text-muted small">@(user?.Email ?? "")</div>
                                </td>
                                <td class="text-muted small">@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <span class="badge bg-secondary">
                                        @(order.OrderType switch { "pre_order" => "Đặt trước", "prescription" => "Theo đơn", _ => "Có sẵn" })
                                    </span>
                                </td>
                                <td>@order.OrderItems.Count sp</td>
                                <td class="fw-bold text-warning">@order.FinalAmount.ToString("N0")₫</td>
                                <td><span class="badge @badgeClass">@statusLabel</span></td>
                                <td>
                                    <form asp-action="UpdateStatus" method="post" class="d-flex gap-1">
                                        <input type="hidden" name="orderId" value="@order.OrderId" />
                                        <select name="status" class="form-select form-select-sm" style="width:130px;">
                                            @{
                                                var s = order.Status;
                                            }
                                            <option value="pending"   selected="@(s=="pending"   ? "selected" : null)">Chờ xử lý</option>
                                            <option value="shipping"  selected="@(s=="shipping"  ? "selected" : null)">Đang giao</option>
                                            <option value="completed" selected="@(s=="completed" ? "selected" : null)">Hoàn thành</option>
                                            <option value="cancelled" selected="@(s=="cancelled" ? "selected" : null)">Đã hủy</option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Lưu</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

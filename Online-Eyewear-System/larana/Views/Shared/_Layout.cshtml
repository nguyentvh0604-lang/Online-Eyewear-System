<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LARANA Glasses</title>

    @* Google Fonts *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    @* Bootstrap Icons (icon only — không load full Bootstrap CSS để tránh xung đột với trang Home) *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    @* LARANA design system — luôn load *@
    <link rel="stylesheet" href="~/css/larana.css" asp-append-version="true" />

    @* Bootstrap CSS — chỉ load ở các trang cần (Cart / Order / Auth / Product list) *@
    @if (ViewData["UseBootstrap"] as bool? == true)
    {
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
        <link rel="stylesheet" href="~/css/bootstrap-fixes.css" asp-append-version="true" />
    }

    @* Slot cho styles riêng của từng trang *@
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @* ── Announcement bar — chỉ hiện ở trang chủ ── *@
    @if (ViewData["ShowAnnouncement"] as bool? == true)
    {
        <div class="announcement-bar">
            <p>Miễn phí vận chuyển cho đơn hàng trên 500.000đ &nbsp;|&nbsp; Đổi trả trong 30 ngày</p>
        </div>
    }

    @* ── Header ── *@
    <header class="header" id="header">
        <div class="header__inner container">
            <button class="btn-icon nav-toggle" aria-label="Mở menu" aria-expanded="false">
                <span class="hamburger">
                    <span></span><span></span><span></span>
                </span>
            </button>

            @* Logo *@
            <a asp-controller="Home" asp-action="Index" class="logo" aria-label="LARANA Glasses — Trang chủ">
                <div class="logo__icon">
                    <svg viewBox="0 0 80 34" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M2 18 C2 10 8 5 17 5 C26 5 32 10 32 18 C32 26 26 30 17 30 C8 30 2 26 2 18Z" stroke="currentColor" stroke-width="2.5" fill="none"/>
                        <path d="M48 18 C48 10 54 5 63 5 C72 5 78 10 78 18 C78 26 72 30 63 30 C54 30 48 26 48 18Z" stroke="currentColor" stroke-width="2.5" fill="none"/>
                        <line x1="32" y1="14" x2="48" y2="14" stroke="currentColor" stroke-width="2.5"/>
                        <ellipse cx="17" cy="18" rx="10" ry="9" fill="var(--primary-gold-light)" opacity="0.45"/>
                        <ellipse cx="63" cy="18" rx="10" ry="9" fill="var(--primary-gold-light)" opacity="0.45"/>
                    </svg>
                </div>
                <div class="logo__text">
                    <span class="logo__name">LARANA</span>
                    <span class="logo__sub">glasses</span>
                </div>
            </a>

            @* Desktop Nav *@
            <nav class="nav" aria-label="Điều hướng chính">
                <ul class="nav__list">
                    <li><a asp-controller="Home" asp-action="Index" class="nav__link">Trang chủ</a></li>
                    <li class="nav__item--has-drop">
                        <a asp-controller="Product" asp-action="Index" class="nav__link">
                            Sản phẩm <span class="nav__caret">›</span>
                        </a>
                        <div class="nav__dropdown">
                            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="1">Kính cận</a>
                            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="2">Kính mát</a>
                            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="3">Kính thể thao</a>
                            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="4">Gọng kính</a>
                        </div>
                    </li>
                    @if (Context.Session.GetInt32("UserId") != null)
                    {
                        <li><a asp-controller="Order" asp-action="History" class="nav__link">Đơn hàng</a></li>
                    }
                </ul>
            </nav>

            @* Header actions *@
            <div class="header__actions">
                @* Giỏ hàng *@
                @{
                    int cartCount = 0;
                    var userId = Context.Session.GetInt32("UserId");
                    if (userId != null)
                        cartCount = OpticalStore.WebApplication.Models.StaticData.GetCartCount(userId.Value);
                }
                <a asp-controller="Cart" asp-action="Index" class="btn-icon" aria-label="Giỏ hàng" style="position:relative;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <path d="M16 10a4 4 0 01-8 0"/>
                    </svg>
                    @if (cartCount > 0)
                    {
                        <span style="position:absolute;top:-6px;right:-6px;background:var(--primary-orange);color:#fff;border-radius:50%;width:18px;height:18px;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;">@cartCount</span>
                    }
                </a>

                @* Auth *@
                @if (userId != null)
                {
                    <div style="display:flex;align-items:center;gap:8px;">
                        <a asp-controller="Auth" asp-action="Profile" class="nav__link" style="font-size:13px;">
                            👤 @Context.Session.GetString("UserName")
                        </a>
                        <a asp-controller="Auth" asp-action="Logout" class="btn btn--ghost btn--sm">Đăng xuất</a>
                    </div>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="btn btn--primary btn--sm">Đăng nhập</a>
                }
            </div>
        </div>
    </header>

    @* ── Main content ── *@
    <main>
        @RenderBody()
    </main>

    @* ── Footer ── *@
    <footer class="footer">
        <div class="container">
            <div class="footer__grid">
                <div class="footer__brand">
                    <a asp-controller="Home" asp-action="Index" class="logo">
                        <div class="logo__icon" style="width:36px;height:36px;">
                            <svg viewBox="0 0 80 34" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M2 18 C2 10 8 5 17 5 C26 5 32 10 32 18 C32 26 26 30 17 30 C8 30 2 26 2 18Z" stroke="currentColor" stroke-width="2.5" fill="none"/>
                                <path d="M48 18 C48 10 54 5 63 5 C72 5 78 10 78 18 C78 26 72 30 63 30 C54 30 48 26 48 18Z" stroke="currentColor" stroke-width="2.5" fill="none"/>
                                <line x1="32" y1="14" x2="48" y2="14" stroke="currentColor" stroke-width="2.5"/>
                            </svg>
                        </div>
                        <div class="logo__text">
                            <span class="logo__name">LARANA</span>
                            <span class="logo__sub">glasses</span>
                        </div>
                    </a>
                    <p class="footer__desc">Cửa hàng mắt kính Larana — thiết kế tinh tế, chất lượng cao cấp. Bài tập ASP.NET Core MVC.</p>
                </div>
                <div>
                    <p class="footer__heading">Sản phẩm</p>
                    <ul class="footer__links">
                        <li><a asp-controller="Product" asp-action="Index" asp-route-categoryId="1">Kính cận</a></li>
                        <li><a asp-controller="Product" asp-action="Index" asp-route-categoryId="2">Kính mát</a></li>
                        <li><a asp-controller="Product" asp-action="Index" asp-route-categoryId="3">Kính thể thao</a></li>
                        <li><a asp-controller="Product" asp-action="Index" asp-route-categoryId="4">Gọng kính</a></li>
                    </ul>
                </div>
                <div>
                    <p class="footer__heading">Tài khoản</p>
                    <ul class="footer__links">
                        <li><a asp-controller="Auth" asp-action="Login">Đăng nhập</a></li>
                        <li><a asp-controller="Auth" asp-action="Register">Đăng ký</a></li>
                        <li><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                        <li><a asp-controller="Order" asp-action="History">Lịch sử đơn</a></li>
                    </ul>
                </div>
                <div>
                    <p class="footer__heading">Hỗ trợ</p>
                    <ul class="footer__links">
                        <li><a href="#">Chính sách đổi trả</a></li>
                        <li><a href="#">Hướng dẫn chọn kính</a></li>
                        <li><a href="#">Liên hệ</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer__bottom">
                <span>&copy; 2025 LARANA Glasses. All rights reserved.</span>
                <span>Bài tập môn ASP.NET Core MVC</span>
            </div>
        </div>
    </footer>

    @* JS sticky header + hamburger *@
    <script>
        const header = document.getElementById('header');
        window.addEventListener('scroll', () => {
            header.classList.toggle('scrolled', window.scrollY > 10);
        });
    </script>

    @* Bootstrap JS — chỉ load khi cần *@
    @if (ViewData["UseBootstrap"] as bool? == true)
    {
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

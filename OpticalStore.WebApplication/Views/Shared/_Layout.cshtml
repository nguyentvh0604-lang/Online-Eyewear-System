@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — OpticalStore</title>
    
    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet" />
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        /* Custom styles cho navbar */
        .navbar-brand { font-weight: 600; }
        .nav-link { font-weight: 500; }
        .nav-link.active { color: #ffc107 !important; }
        .badge-cart { 
            position: absolute; 
            top: -5px; 
            right: -10px; 
            font-size: 0.7rem; 
        }
    </style>
</head>
<body>
    <!-- ================= NAVBAR ================= -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <!-- Brand -->
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-eye-fill me-2"></i>OpticalStore
            </a>

            <!-- Toggle Button for Mobile -->
            <button class="navbar-toggler" type="button" 
                    data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" 
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Navbar Content -->
            <div class="collapse navbar-collapse" id="mainNavbar">
                
                <!-- Left: Navigation Links -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <!-- Home -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door me-1"></i>Trang chủ
                        </a>
                    </li>

                    <!-- Products -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Index">
                            <i class="bi bi-grid me-1"></i>Sản phẩm
                        </a>
                    </li>

                    <!-- Cart (chỉ hiện khi đã đăng nhập) -->
                    @if (Context.User?.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link position-relative" 
                               asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart me-1"></i>Giỏ hàng
                                <!-- Badge số lượng (cần controller truyền ViewBag.CartCount) -->
                                @if (ViewBag.CartCount != null && ViewBag.CartCount > 0)
                                {
                                    <span class="badge bg-danger rounded-pill badge-cart">
                                        @ViewBag.CartCount
                                    </span>
                                }
                            </a>
                        </li>
                    }

                    <!-- Order History (chỉ hiện khi đã đăng nhập) -->
                    @if (Context.User?.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Order" asp-action="History">
                                <i class="bi bi-receipt me-1"></i>Đơn hàng
                            </a>
                        </li>
                    }

                    <!-- Staff Menu (chỉ hiện cho nhân viên) -->
                    @if (Context.User?.IsInRole("sales_staff") == true || 
                         Context.User?.IsInRole("operations_staff") == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-warning" 
                               href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-briefcase me-1"></i>Quản lý đơn
                            </a>
                            <ul class="dropdown-menu">
                                @if (Context.User.IsInRole("sales_staff"))
                                {
                                    <li><a class="dropdown-item" asp-controller="Order" asp-action="PendingOrders">Đơn chờ xử lý</a></li>
                                    <li><a class="dropdown-item" asp-controller="Prescription" asp-action="Verify">Xác nhận đơn kính</a></li>
                                }
                                @if (Context.User.IsInRole("operations_staff"))
                                {
                                    <li><a class="dropdown-item" asp-controller="Shipment" asp-action="Index">Quản lý vận chuyển</a></li>
                                    <li><a class="dropdown-item" asp-controller="Inventory" asp-action="Index">Quản lý tồn kho</a></li>
                                }
                            </ul>
                        </li>
                    }

                    <!-- Manager/Admin Menu -->
                    @if (Context.User?.IsInRole("manager") == true || 
                         Context.User?.IsInRole("admin") == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-danger" 
                               href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-gear me-1"></i>Quản trị
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Manage">Quản lý sản phẩm</a></li>
                                <li><a class="dropdown-item" asp-controller="Promotion" asp-action="Index">Khuyến mãi</a></li>
                                <li><a class="dropdown-item" asp-controller="User" asp-action="Index">Người dùng</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="Report" asp-action="Revenue">Báo cáo doanh thu</a></li>
                            </ul>
                        </li>
                    }
                </ul>

                <!-- Right: User Account / Auth -->
                <ul class="navbar-nav">
                    @if (Context.User?.Identity?.IsAuthenticated == true)
                    {
                        <!-- Hiển thị khi đã đăng nhập -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" 
                               href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-2 fs-5"></i>
                                <span>@Context.User?.FindFirst(ClaimTypes.Name)?.Value</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                        <i class="bi bi-person me-2"></i>Thông tin cá nhân
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Order" asp-action="History">
                                        <i class="bi bi-clock-history me-2"></i>Lịch sử mua hàng
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <!-- Hiển thị khi chưa đăng nhập -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus me-1"></i>Đăng ký
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <!-- ================= END NAVBAR ================= -->

    <!-- Main Content -->
    <main role="main" class="container mt-4" style="min-height: 70vh;">
        <!-- Hiển thị thông báo (TempData) -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white text-center py-4 mt-5">
        <div class="container">
            <p class="mb-2">© 2025 OpticalStore — Nhóm 4, Môn Lập trình Web</p>
            <p class="mb-0 small text-muted">
                <i class="bi bi-geo-alt me-1"></i>Hệ thống bán kính mắt trực tuyến
            </p>
        </div>
    </footer>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- jQuery (nếu cần) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    
    <!-- Custom JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
    
    <!-- Script tự động ẩn alert sau 5 giây -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                setTimeout(function() {
                    var bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                }, 5000);
            });
        });
    </script>
</body>
</html>
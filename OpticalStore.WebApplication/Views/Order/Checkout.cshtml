@model OpticalStore.Services.Interfaces.CheckoutDto

@{
    ViewData["Title"] = "Thanh toán";
}

<h2>Thanh toán</h2>

<form asp-action="Checkout" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <!-- Thông tin giao hàng -->
    <div class="card mb-3">
        <div class="card-header">Thông tin giao hàng</div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Địa chỉ nhận hàng</label>
                <textarea asp-for="ShippingAddress" class="form-control" rows="3" required></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Ghi chú</label>
                <textarea asp-for="Note" class="form-control" rows="2"></textarea>
            </div>
        </div>
    </div>

    <!-- Loại đơn hàng -->
    <div class="card mb-3">
        <div class="card-header">Loại đơn hàng</div>
        <div class="card-body">
            <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="OrderType" value="standard" id="standardOrder" checked>
                <label class="form-check-label" for="standardOrder">
                    Mua kính có sẵn
                </label>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="OrderType" value="pre_order" id="preOrder">
                <label class="form-check-label" for="preOrder">
                    Đặt trước (Pre-order)
                </label>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="IsPrescriptionOrder" value="true" id="prescriptionOrder">
                <label class="form-check-label" for="prescriptionOrder">
                    Làm kính theo đơn
                </label>
            </div>

            <!-- Phần chọn prescription (hiện khi chọn prescription order) -->
            <div id="prescriptionSection" style="display: none;" class="mt-3">
                <div class="mb-3">
                    <label class="form-label">Chọn đơn kính cũ (nếu có)</label>
                    <select asp-for="ExistingPrescriptionId" class="form-select">
                        <option value="">-- Nhập thông số mới --</option>
                        @if (ViewBag.Prescriptions != null)
                        {
                            @foreach (var p in ViewBag.Prescriptions)
                            {
                                <option value="@p.PrescriptionId">
                                    Đơn ngày @p.CreatedAt.ToString("dd/MM/yyyy")
                                </option>
                            }
                        }
                    </select>
                </div>

                <!-- Form nhập prescription mới -->
                <div class="row">
                    <div class="col-md-6">
                        <h6>Mắt phải (OD)</h6>
                        <div class="mb-2">
                            <label>Sphere</label>
                            <input type="number" step="0.25" class="form-control" name="NewPrescription.OdSphere" />
                        </div>
                        <div class="mb-2">
                            <label>Cylinder</label>
                            <input type="number" step="0.25" class="form-control" name="NewPrescription.OdCylinder" />
                        </div>
                        <div class="mb-2">
                            <label>Axis</label>
                            <input type="number" class="form-control" name="NewPrescription.OdAxis" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h6>Mắt trái (OS)</h6>
                        <div class="mb-2">
                            <label>Sphere</label>
                            <input type="number" step="0.25" class="form-control" name="NewPrescription.OsSphere" />
                        </div>
                        <div class="mb-2">
                            <label>Cylinder</label>
                            <input type="number" step="0.25" class="form-control" name="NewPrescription.OsCylinder" />
                        </div>
                        <div class="mb-2">
                            <label>Axis</label>
                            <input type="number" class="form-control" name="NewPrescription.OsAxis" />
                        </div>
                    </div>
                </div>
                <div class="mb-2">
                    <label>PD (khoảng cách đồng tử)</label>
                    <input type="number" step="0.5" class="form-control" name="NewPrescription.Pd" />
                </div>
            </div>
        </div>
    </div>

    <div class="text-end">
        <button type="submit" class="btn btn-primary btn-lg">Đặt hàng</button>
    </div>
</form>

<script>
    // Show/hide prescription section
    document.getElementById('prescriptionOrder').addEventListener('change', function() {
        document.getElementById('prescriptionSection').style.display = this.checked ? 'block' : 'none';
    });
</script>
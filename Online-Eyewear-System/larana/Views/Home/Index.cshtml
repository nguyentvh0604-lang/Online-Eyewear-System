@{
    ViewData["Title"] = "Trang chủ";
    ViewData["ShowAnnouncement"] = true;
}

@* ===== HERO ===== *@
<section class="hero" aria-labelledby="hero-heading">
    <div class="hero__bg">
        <div class="hero__circle hero__circle--1"></div>
        <div class="hero__circle hero__circle--2"></div>
    </div>
    <div class="container hero__inner">
        <div class="hero__content">
            <span class="hero__badge">New Collection 2025</span>
            <h1 class="hero__heading" id="hero-heading">
                Đôi mắt bạn<br />
                <em>xứng đáng</em> được<br />
                tỏa sáng
            </h1>
            <p class="hero__desc">
                Bộ sưu tập kính mắt thời trang — thiết kế tinh tế, chất liệu cao cấp, phong cách vượt thời gian.
            </p>
            <div class="hero__actions">
                <a asp-controller="Product" asp-action="Index" class="btn btn--primary btn--lg">Khám phá ngay</a>
                <a asp-controller="Product" asp-action="Index" class="btn btn--ghost btn--lg">Xem bộ sưu tập</a>
            </div>
            <div class="hero__stats">
                <div class="hero__stat">
                    <span class="hero__stat-num">500+</span>
                    <span class="hero__stat-label">Mẫu kính</span>
                </div>
                <div class="hero__stat-divider"></div>
                <div class="hero__stat">
                    <span class="hero__stat-num">10K+</span>
                    <span class="hero__stat-label">Khách hàng</span>
                </div>
                <div class="hero__stat-divider"></div>
                <div class="hero__stat">
                    <span class="hero__stat-num">4.9★</span>
                    <span class="hero__stat-label">Đánh giá</span>
                </div>
            </div>
        </div>
        <div class="hero__visual">
            <div class="hero__frame">
                <div class="hero__glasses-display">
                    <svg viewBox="0 0 320 160" fill="none" xmlns="http://www.w3.org/2000/svg" class="hero__glasses-svg" aria-hidden="true">
                        <ellipse cx="82" cy="82" rx="68" ry="62" fill="var(--primary-gold-light)" opacity="0.3"/>
                        <ellipse cx="238" cy="82" rx="68" ry="62" fill="var(--primary-gold-light)" opacity="0.3"/>
                        <path d="M14 72 C14 40 42 18 82 18 C122 18 150 40 150 72 C150 104 122 130 82 130 C42 130 14 104 14 72Z" stroke="var(--primary-orange)" stroke-width="5" fill="var(--primary-gold-light)" fill-opacity="0.25"/>
                        <path d="M170 72 C170 40 198 18 238 18 C278 18 306 40 306 72 C306 104 278 130 238 130 C198 130 170 104 170 72Z" stroke="var(--primary-orange)" stroke-width="5" fill="var(--primary-gold-light)" fill-opacity="0.25"/>
                        <line x1="150" y1="55" x2="170" y2="55" stroke="var(--primary-orange)" stroke-width="5" stroke-linecap="round"/>
                        <line x1="14" y1="55" x2="-10" y2="28" stroke="var(--primary-orange)" stroke-width="4" stroke-linecap="round"/>
                        <line x1="306" y1="55" x2="330" y2="28" stroke="var(--primary-orange)" stroke-width="4" stroke-linecap="round"/>
                    </svg>
                    <div class="hero__tag hero__tag--1">Cat-eye</div>
                    <div class="hero__tag hero__tag--2">Rose tinted</div>
                </div>
            </div>
            <div class="hero__floats">
                <div class="hero__float hero__float--a">✦ Premium</div>
                <div class="hero__float hero__float--b">UV400</div>
            </div>
        </div>
    </div>
</section>

@* ===== CATEGORIES ===== *@
<section class="categories section" aria-labelledby="categories-heading">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title" id="categories-heading">Danh mục</h2>
            <a asp-controller="Product" asp-action="Index" class="section-link">Xem tất cả →</a>
        </div>
        <div class="categories__grid">
            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="1" class="category-card category-card--large">
                <div class="category-card__bg category-card__bg--1"></div>
                <div class="category-card__content">
                    <span class="category-card__label">Kính cận</span>
                    <span class="category-card__count">120+ mẫu</span>
                </div>
            </a>
            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="2" class="category-card">
                <div class="category-card__bg category-card__bg--2"></div>
                <div class="category-card__content">
                    <span class="category-card__label">Kính mát</span>
                    <span class="category-card__count">90+ mẫu</span>
                </div>
            </a>
            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="3" class="category-card">
                <div class="category-card__bg category-card__bg--3"></div>
                <div class="category-card__content">
                    <span class="category-card__label">Thể thao</span>
                    <span class="category-card__count">60+ mẫu</span>
                </div>
            </a>
        </div>
    </div>
</section>

@* ===== FEATURED PRODUCTS ===== *@
<section class="products section" aria-labelledby="products-heading">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title" id="products-heading">Nổi bật</h2>
            <a asp-controller="Product" asp-action="Index" class="section-link">Xem thêm →</a>
        </div>
        <div class="products__grid">

            @* Card 1 *@
            <article class="product-card">
                <div class="product-card__media">
                    <div class="product-card__img-wrap">
                        <div class="product-card__img-placeholder">
                            <svg viewBox="0 0 200 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M12 44C12 26 30 15 52 15C74 15 92 26 92 44C92 62 74 75 52 75C30 75 12 62 12 44Z" stroke="var(--primary-orange)" stroke-width="3" fill="var(--primary-gold-light)" fill-opacity="0.5"/>
                                <path d="M108 44C108 26 126 15 148 15C170 15 188 26 188 44C188 62 170 75 148 75C126 75 108 62 108 44Z" stroke="var(--primary-orange)" stroke-width="3" fill="var(--primary-gold-light)" fill-opacity="0.5"/>
                                <line x1="92" y1="34" x2="108" y2="34" stroke="var(--primary-orange)" stroke-width="3"/>
                                <line x1="12" y1="34" x2="2" y2="22" stroke="var(--primary-orange)" stroke-width="2.5"/>
                                <line x1="188" y1="34" x2="198" y2="22" stroke="var(--primary-orange)" stroke-width="2.5"/>
                            </svg>
                        </div>
                    </div>
                    <div class="product-card__badge">New</div>
                </div>
                <div class="product-card__info">
                    <div class="product-card__meta">
                        <span class="product-card__category">Kính cận</span>
                        <div class="product-card__rating"><span class="star">★★★★★</span><span class="product-card__rating-count">(42)</span></div>
                    </div>
                    <h3 class="product-card__name">Ray-Ban RB5154</h3>
                    <p class="product-card__desc">Gọng acetate cao cấp, dáng clubmaster vượt thời gian</p>
                    <div class="product-card__footer">
                        <div class="product-card__price">
                            <span class="price-current">2.850.000₫</span>
                        </div>
                        <a asp-controller="Product" asp-action="Detail" asp-route-id="1" class="btn btn--primary btn--sm">Xem chi tiết</a>
                    </div>
                </div>
            </article>

            @* Card 2 *@
            <article class="product-card">
                <div class="product-card__media">
                    <div class="product-card__img-wrap">
                        <div class="product-card__img-placeholder product-card__img-placeholder--dark">
                            <svg viewBox="0 0 200 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <ellipse cx="52" cy="50" rx="38" ry="30" stroke="var(--primary-orange)" stroke-width="3" fill="none"/>
                                <ellipse cx="148" cy="50" rx="38" ry="30" stroke="var(--primary-orange)" stroke-width="3" fill="none"/>
                                <line x1="90" y1="38" x2="110" y2="38" stroke="var(--primary-orange)" stroke-width="3"/>
                                <line x1="14" y1="38" x2="4" y2="25" stroke="var(--primary-orange)" stroke-width="2.5"/>
                                <line x1="186" y1="38" x2="196" y2="25" stroke="var(--primary-orange)" stroke-width="2.5"/>
                            </svg>
                        </div>
                    </div>
                    <div class="product-card__badge product-card__badge--sale">-20%</div>
                </div>
                <div class="product-card__info">
                    <div class="product-card__meta">
                        <span class="product-card__category">Kính mát</span>
                        <div class="product-card__rating"><span class="star">★★★★★</span><span class="product-card__rating-count">(67)</span></div>
                    </div>
                    <h3 class="product-card__name">Gucci GG0061S</h3>
                    <p class="product-card__desc">Cat-eye biểu tượng, tròng phân cực UV400</p>
                    <div class="product-card__footer">
                        <div class="product-card__price">
                            <span class="price-current">6.800.000₫</span>
                            <span class="price-old">8.500.000₫</span>
                        </div>
                        <a asp-controller="Product" asp-action="Detail" asp-route-id="3" class="btn btn--primary btn--sm">Xem chi tiết</a>
                    </div>
                </div>
            </article>

            @* Card 3 *@
            <article class="product-card">
                <div class="product-card__media">
                    <div class="product-card__img-wrap">
                        <div class="product-card__img-placeholder product-card__img-placeholder--pink">
                            <svg viewBox="0 0 200 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M10 50 C10 30 25 10 55 15 C75 18 90 35 90 50 C90 65 75 75 55 72 C30 68 10 68 10 50Z" stroke="var(--primary-orange)" stroke-width="3" fill="var(--primary-gold-light)" fill-opacity="0.5"/>
                                <path d="M190 50 C190 30 175 10 145 15 C125 18 110 35 110 50 C110 65 125 75 145 72 C170 68 190 68 190 50Z" stroke="var(--primary-orange)" stroke-width="3" fill="var(--primary-gold-light)" fill-opacity="0.5"/>
                                <line x1="90" y1="38" x2="110" y2="38" stroke="var(--primary-orange)" stroke-width="3"/>
                                <line x1="10" y1="38" x2="0" y2="24" stroke="var(--primary-orange)" stroke-width="2.5"/>
                                <line x1="190" y1="38" x2="200" y2="24" stroke="var(--primary-orange)" stroke-width="2.5"/>
                            </svg>
                        </div>
                    </div>
                </div>
                <div class="product-card__info">
                    <div class="product-card__meta">
                        <span class="product-card__category">Thể thao</span>
                        <div class="product-card__rating"><span class="star">★★★★★</span><span class="product-card__rating-count">(31)</span></div>
                    </div>
                    <h3 class="product-card__name">Oakley Radar EV</h3>
                    <p class="product-card__desc">Khí động học, tròng Prizm™ tăng độ tương phản</p>
                    <div class="product-card__footer">
                        <div class="product-card__price">
                            <span class="price-current">6.800.000₫</span>
                        </div>
                        <a asp-controller="Product" asp-action="Detail" asp-route-id="5" class="btn btn--primary btn--sm">Xem chi tiết</a>
                    </div>
                </div>
            </article>

            @* Card 4 *@
            <article class="product-card">
                <div class="product-card__media">
                    <div class="product-card__img-wrap">
                        <div class="product-card__img-placeholder product-card__img-placeholder--cream">
                            <svg viewBox="0 0 200 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <rect x="12" y="28" width="80" height="50" rx="8" stroke="var(--primary-orange)" stroke-width="3.5" fill="var(--primary-orange-light)" fill-opacity="0.15"/>
                                <rect x="108" y="28" width="80" height="50" rx="8" stroke="var(--primary-orange)" stroke-width="3.5" fill="var(--primary-orange-light)" fill-opacity="0.15"/>
                                <line x1="92" y1="42" x2="108" y2="42" stroke="var(--primary-orange)" stroke-width="3.5"/>
                                <line x1="12" y1="42" x2="2" y2="30" stroke="var(--primary-orange)" stroke-width="2.5"/>
                                <line x1="188" y1="42" x2="198" y2="30" stroke="var(--primary-orange)" stroke-width="2.5"/>
                            </svg>
                        </div>
                    </div>
                    <div class="product-card__badge product-card__badge--popular">Hot</div>
                </div>
                <div class="product-card__info">
                    <div class="product-card__meta">
                        <span class="product-card__category">Gọng kính</span>
                        <div class="product-card__rating"><span class="star">★★★★★</span><span class="product-card__rating-count">(89)</span></div>
                    </div>
                    <h3 class="product-card__name">Silhouette 5515</h3>
                    <p class="product-card__desc">Không vành, titanium, chỉ 1.8g — nhẹ như không đeo</p>
                    <div class="product-card__footer">
                        <div class="product-card__price">
                            <span class="price-current">7.200.000₫</span>
                        </div>
                        <a asp-controller="Product" asp-action="Detail" asp-route-id="7" class="btn btn--primary btn--sm">Xem chi tiết</a>
                    </div>
                </div>
            </article>
        </div>

        <div class="products__load-more">
            <a asp-controller="Product" asp-action="Index" class="btn btn--outline btn--lg">Xem thêm sản phẩm</a>
        </div>
    </div>
</section>

@* ===== PROMO BANNER ===== *@
<section class="promo section" aria-label="Ưu đãi đặc biệt">
    <div class="container">
        <div class="promo__card">
            <div class="promo__content">
                <span class="promo__eyebrow">Limited offer</span>
                <h2 class="promo__title">Giảm đến <em>30%</em> bộ sưu tập hè</h2>
                <p class="promo__desc">Ưu đãi có hạn — chỉ còn 3 ngày. Nhanh tay chọn kính yêu thích!</p>
                <div class="promo__actions">
                    <a asp-controller="Product" asp-action="Index" class="btn btn--white btn--lg">Mua ngay</a>
                    <a asp-controller="Product" asp-action="Index" class="btn btn--ghost-white btn--lg">Xem chi tiết</a>
                </div>
            </div>
            <div class="promo__visual" aria-hidden="true">
                <div class="promo__circle"></div>
                <svg viewBox="0 0 260 130" fill="none" xmlns="http://www.w3.org/2000/svg" class="promo__glasses">
                    <path d="M10 58C10 33 34 13 65 13C96 13 120 33 120 58C120 83 96 103 65 103C34 103 10 83 10 58Z" stroke="white" stroke-width="4" fill="none"/>
                    <path d="M140 58C140 33 164 13 195 13C226 13 250 33 250 58C250 83 226 103 195 103C164 103 140 83 140 58Z" stroke="white" stroke-width="4" fill="none"/>
                    <line x1="120" y1="45" x2="140" y2="45" stroke="white" stroke-width="4"/>
                    <line x1="10" y1="45" x2="-5" y2="28" stroke="white" stroke-width="3.5"/>
                    <line x1="250" y1="45" x2="265" y2="28" stroke="white" stroke-width="3.5"/>
                </svg>
            </div>
        </div>
    </div>
</section>

@* ===== TESTIMONIALS ===== *@
<section class="testimonials section" aria-labelledby="testimonials-heading">
    <div class="container">
        <div class="section-header section-header--centered">
            <h2 class="section-title" id="testimonials-heading">Khách hàng nói gì</h2>
        </div>
        <div class="testimonials__grid">
            <blockquote class="testimonial-card">
                <div class="testimonial-card__stars" aria-label="5 sao">★★★★★</div>
                <p class="testimonial-card__text">"Kính đẹp hơn mong đợi, gọng chắc chắn và nhẹ. Đội ngũ tư vấn nhiệt tình, sẽ ủng hộ dài dài!"</p>
                <footer class="testimonial-card__author">
                    <div class="testimonial-card__avatar" aria-hidden="true">M</div>
                    <div>
                        <div class="testimonial-card__name">Minh Anh</div>
                        <div class="testimonial-card__location">TP. Hồ Chí Minh</div>
                    </div>
                </footer>
            </blockquote>
            <blockquote class="testimonial-card">
                <div class="testimonial-card__stars" aria-label="5 sao">★★★★★</div>
                <p class="testimonial-card__text">"Mua kính lần 3 rồi, lần nào cũng hài lòng. Chất lượng xứng với giá, giao hàng nhanh."</p>
                <footer class="testimonial-card__author">
                    <div class="testimonial-card__avatar testimonial-card__avatar--b" aria-hidden="true">T</div>
                    <div>
                        <div class="testimonial-card__name">Thanh Hương</div>
                        <div class="testimonial-card__location">Hà Nội</div>
                    </div>
                </footer>
            </blockquote>
            <blockquote class="testimonial-card">
                <div class="testimonial-card__stars" aria-label="5 sao">★★★★★</div>
                <p class="testimonial-card__text">"Kính cat-eye rose cực kỳ hợp với khuôn mặt tròn. Nhân viên tư vấn rất chuyên nghiệp!"</p>
                <footer class="testimonial-card__author">
                    <div class="testimonial-card__avatar testimonial-card__avatar--c" aria-hidden="true">L</div>
                    <div>
                        <div class="testimonial-card__name">Lan Phương</div>
                        <div class="testimonial-card__location">Đà Nẵng</div>
                    </div>
                </footer>
            </blockquote>
        </div>
    </div>
</section>

@* ── Newsletter ─────────────────────────────────────────── *@
<section class="newsletter" aria-labelledby="newsletter-title">
    <div class="container">
        <div class="newsletter__inner">
            <h2 class="newsletter__title" id="newsletter-title">Đăng ký nhận ưu đãi</h2>
            <p class="newsletter__desc">Nhận thông báo sản phẩm mới và ưu đãi độc quyền trước tiên.</p>
            <div class="newsletter__form">
                <input type="email" class="newsletter__input" placeholder="Email của bạn..." aria-label="Địa chỉ email" />
                <button type="button" class="newsletter__submit" onclick="alert('Cảm ơn bạn đã đăng ký!')">Đăng ký</button>
            </div>
        </div>
    </div>
</section>

@* ── Features / Trust bar ─────────────────────────────── *@
<section class="features" aria-label="Cam kết dịch vụ">
    <div class="container">
        <div class="features__grid">
            <div class="feature-item">
                <div class="feature-item__icon">🚚</div>
                <div class="feature-item__title">Miễn phí vận chuyển</div>
                <div class="feature-item__desc">Cho đơn hàng từ 500.000₫ toàn quốc</div>
            </div>
            <div class="feature-item">
                <div class="feature-item__icon">🔄</div>
                <div class="feature-item__title">Đổi trả 30 ngày</div>
                <div class="feature-item__desc">Không hài lòng? Hoàn tiền 100%</div>
            </div>
            <div class="feature-item">
                <div class="feature-item__icon">🔒</div>
                <div class="feature-item__title">Bảo hành chính hãng</div>
                <div class="feature-item__desc">Tất cả sản phẩm có tem bảo hành 12 tháng</div>
            </div>
            <div class="feature-item">
                <div class="feature-item__icon">💬</div>
                <div class="feature-item__title">Hỗ trợ 24/7</div>
                <div class="feature-item__desc">Đội ngũ tư vấn chuyên nghiệp luôn sẵn sàng</div>
            </div>
        </div>
    </div>
</section>
